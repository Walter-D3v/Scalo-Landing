---
import '../styles/global.css';
import LeadCaptureModal from '../components/LeadCaptureModal.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = 'Scalo - Business Intelligence de Próxima Generación',
  description = 'Transforma tus datos en decisiones estratégicas con Scalo. La plataforma de análisis más rápida e intuitiva para startups modernas.'
} = Astro.props;
---

<!doctype html>
<html lang="es" class="bg-deep-navy">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#030712" />
    
    <title>{title}</title>
    
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    
    <!-- Google Fonts: Inter & Space Grotesk -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content="/og-image.png" />
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
  </head>
  <body class="bg-nebula min-h-screen">
    <div id="smooth-wrapper">
      <div id="smooth-content">
        <slot />
      </div>
    </div>

    <!-- Modals -->
    <LeadCaptureModal />

    <!-- Lenis Smooth Scroll -->
    <script>
      import Lenis from 'lenis';
      
      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        wheelMultiplier: 1,
        touchMultiplier: 2,
        infinite: false,
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }

      requestAnimationFrame(raf);
    </script>
  </body>
</html>
