---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Hero from '../components/Hero.astro';
import FeatureBento from '../components/FeatureBento.astro';
import ProblemSection from '../components/ProblemSection.astro';
import HowItWorksSteps from '../components/react/HowItWorksSteps';
import AnimatedBlog from '../components/react/AnimatedBlog';
import Footer from '../components/Footer.astro';
import TestimonialAccordion from '../components/react/TestimonialAccordion';
---

<Layout title="Scalo - Business Intelligence de Próxima Generación">
  <NavBar />
  
  <main>
    <Hero />
    
    <ProblemSection />
    
    <FeatureBento />
    
    <section class="py-10 bg-deep-navy relative overflow-hidden">
        <HowItWorksSteps client:visible />
    </section>
    
    <!-- Accordion Feedback Section (Soluciones) -->
    <section id="soluciones" class="py-20 relative overflow-hidden">
      <div class="container mx-auto px-6 relative z-10">
        <div class="text-center mb-16">
          <h2 class="text-3xl md:text-5xl font-black mb-6 font-outfit uppercase tracking-tighter">
            Empresas que ya <span class="text-scalo-accent-violet">Entienden su negocio</span>
          </h2>
          <p class="max-w-xl mx-auto text-slate-400">
            Descubre lo que las empresas líderes opinan sobre nuestra plataforma y cómo han transformado sus datos en decisiones accionables.
          </p>
        </div>
        
        <TestimonialAccordion client:visible />
      </div>
      
      <!-- Decorative background for accordion -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-scalo-accent-violet/5 blur-[120px] -z-10 rounded-full pointer-events-none"></div>
    </section>

    <!-- Blog Section instead of Pricing -->
    <AnimatedBlog client:visible />
    
    <!-- CTA Middle Section -->
    <section class="py-20 relative overflow-hidden">
      <div class="container mx-auto px-6">
        <div class="glass-card p-12 md:p-20 rounded-[40px] text-center relative overflow-hidden">
          <div id="tsparticles" class="absolute inset-0 z-0 pointer-events-none"></div>
          <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-scalo-primary/20 via-transparent to-scalo-accent-cyan/20 animate-pulse z-0"></div>
          
          <div class="relative z-10">
            <h2 class="text-4xl md:text-6xl font-black mb-8 font-outfit uppercase tracking-tighter leading-tight">
              ¿Listo para dar el <br /> <span class="text-scalo-accent-cyan">Siguiente Paso?</span>
            </h2>
            <p class="max-w-2xl mx-auto text-lg text-slate-400 mb-10 leading-relaxed">
              Únete a cientos de empresas que ya están transformando sus datos en activos estratégicos. 
              Prueba Scalo gratis por 14 días. No requiere tarjeta.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
              <button 
                onclick="window.openLeadModal && window.openLeadModal()" 
                class="w-full sm:w-auto bg-white text-deep-navy px-10 py-4 rounded-2xl font-bold text-lg hover:bg-scalo-accent-cyan hover:scale-105 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-deep-navy"
                aria-label="Abre el formulario para empezar ahora"
              >
                Empezar Ahora
              </button>
              <button 
                onclick="window.openLeadModal && window.openLeadModal()" 
                class="w-full sm:w-auto glass text-white px-10 py-4 rounded-2xl font-bold text-lg hover:bg-white/10 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-deep-navy"
                aria-label="Contactar a un experto"
              >
                Hablar con un Experto
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    // Reveal animation logic
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          if (entry.target instanceof HTMLElement) {
             entry.target.style.opacity = '1';
             entry.target.style.transform = 'translateY(0)';
          }
        }
      });
    }, observerOptions);

    document.querySelectorAll('.animate-reveal').forEach(el => {
      observer.observe(el);
    });
  </script>

  <script is:inline src="https://cdn.jsdelivr.net/npm/tsparticles-preset-stars@2/tsparticles.preset.stars.bundle.min.js"></script>
  <script is:inline>
    document.addEventListener("DOMContentLoaded", function () {
      if (typeof tsParticles !== 'undefined') {
        tsParticles.load("tsparticles", {
          preset: "stars",
          background: { color: { value: "transparent" } },
          particles: {
            number: { value: 120, density: { enable: true, value_area: 800 } },
            size: { value: 2 },
            opacity: { value: 0.5, animation: { enable: true, speed: 1, minimumValue: 0.1 } },
            move: { enable: true, speed: 0.2, direction: "none", random: true, straight: false }
          }
        });
      }
    });
  </script>
</Layout>
