---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Hero from '../components/Hero.astro';
import FeatureBento from '../components/FeatureBento.astro';
import ProblemSection from '../components/ProblemSection.astro';
import HowItWorksSteps from '../components/react/HowItWorksSteps';
import AnimatedBlog from '../components/react/AnimatedBlog';
import Footer from '../components/Footer.astro';
import TestimonialAccordion from '../components/react/TestimonialAccordion';
import { getFeaturedPosts, getOpinions, normalizeUrl } from '../lib/content-island';

const blogPosts = await getFeaturedPosts(3);
const rawOpinions = await getOpinions(6);

const colors = ['#6366f1', '#06b6d4', '#8b5cf6', '#ec4899', '#f59e0b', '#10b981'];

const testimonials = rawOpinions.length > 0 
  ? rawOpinions.map((op, index) => ({
      author: op.name,
      role: op.source || '',
      feedback: op.content,
      rating: op.ranking || 5,
      accent: colors[index % colors.length],
      initials: op.name.split(' ').map((n: string) => n[0]).join('').substring(0, 2).toUpperCase(),
      avatar: normalizeUrl(op.avatar),
    }))
  : undefined;
---

<Layout title="Scalo - Business Intelligence de Próxima Generación">
  <NavBar />
  
  <main>
    <Hero />
    
    <ProblemSection />
    
    <FeatureBento />
    
    <section class="py-10 bg-deep-navy relative overflow-hidden">
        <HowItWorksSteps client:idle />
    </section>
    
    <!-- Testimonial Marquee Carousel -->
    <section id="soluciones" class="py-20 relative overflow-hidden bg-deep-navy border-t border-white/5">
      <!-- Header -->
      <div class="container mx-auto px-6 text-center mb-12 relative z-10">
        <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-widest text-scalo-accent-violet border border-scalo-accent-violet/30 rounded-full mb-4">
          Testimonios
        </span>
        <h2 class="text-3xl md:text-5xl font-black mb-4 font-outfit uppercase tracking-tighter">
          Empresas que ya <span class="text-scalo-accent-violet">Entienden su negocio</span>
        </h2>
        <p class="max-w-xl mx-auto text-slate-400">
          Lo que las empresas líderes dicen sobre cómo Scalo transformó sus datos en decisiones accionables.
        </p>
      </div>

      <!-- Full-bleed marquee (no px container) -->
      <TestimonialAccordion client:idle testimonials={testimonials} />

      <!-- Glow -->
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[400px] bg-scalo-accent-violet/5 blur-[120px] -z-10 rounded-full pointer-events-none"></div>
    </section>

    <!-- Blog Section instead of Pricing -->
    <AnimatedBlog client:idle posts={blogPosts} />
    
    <!-- CTA Middle Section -->
    <section class="py-20 relative overflow-hidden">
      <div class="container mx-auto px-6">
        <div class="glass-card p-12 md:p-20 rounded-[40px] text-center relative overflow-hidden">
          <div id="tsparticles" class="absolute inset-0 z-0 pointer-events-none"></div>
          <div class="absolute top-0 left-0 w-full h-full bg-gradient-to-br from-scalo-primary/20 via-transparent to-scalo-accent-cyan/20 z-0"></div>
          
          <div class="relative z-10">
            <h2 class="text-3xl md:text-5xl lg:text-6xl font-black mb-6 md:mb-8 font-outfit uppercase tracking-tighter leading-tight">
              ¿Listo para dar el <br /> <span class="text-scalo-accent-cyan">Siguiente Paso?</span>
            </h2>
            <p class="max-w-2xl mx-auto text-lg text-slate-400 mb-10 leading-relaxed">
              Únete a cientos de empresas que ya están transformando sus datos en activos estratégicos. 
              Prueba Scalo gratis por 14 días. No requiere tarjeta.
            </p>
            <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
              <button 
                onclick="window.openLeadModal && window.openLeadModal()" 
                class="w-full sm:w-auto bg-white text-deep-navy px-10 py-4 rounded-2xl font-bold text-lg hover:bg-scalo-accent-cyan hover:scale-105 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-deep-navy"
                aria-label="Abre el formulario para empezar ahora"
              >
                Empezar Ahora
              </button>
              <button 
                onclick="window.openLeadModal && window.openLeadModal()" 
                class="w-full sm:w-auto glass text-white px-10 py-4 rounded-2xl font-bold text-lg hover:bg-white/10 transition-all duration-300 focus:outline-none focus:ring-2 focus:ring-white focus:ring-offset-2 focus:ring-offset-deep-navy"
                aria-label="Contactar a un experto"
              >
                Hablar con un Experto
              </button>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    // Reveal animation logic
    const observerOptions = {
      threshold: 0.1,
      rootMargin: '0px 0px -50px 0px'
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          if (entry.target instanceof HTMLElement) {
             entry.target.style.opacity = '1';
             entry.target.style.transform = 'translateY(0)';
          }
        }
      });
    }, observerOptions);

    document.querySelectorAll('.animate-reveal').forEach(el => {
      observer.observe(el);
    });
  </script>


</Layout>
