---
import Layout from '../layouts/Layout.astro';
import NavBar from '../components/NavBar.astro';
import Hero from '../components/Hero.astro';
import CompaniesLogos from '../components/CompaniesLogos.astro';
import FeatureBlocks from '../components/FeatureBlocks.astro';
import HowItWorksCards from '../components/HowItWorksCards.astro';
import BuildTogetherCTA from '../components/BuildTogetherCTA.astro';
import FaqAccordion from '../components/react/FaqAccordion';
import FinalCTA from '../components/FinalCTA.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Scalo - Business Intelligence de Próxima Generación"
  description="Scalo convierte la información de tu empresa en decisiones concretas. Sin reportes que nadie lee. Sin consultores caros."
  theme="light"
>
  <NavBar variant="light" />

  <main>
    <Hero />
    <CompaniesLogos />
    <FeatureBlocks />
    <HowItWorksCards />
    <BuildTogetherCTA />

    <section id="faqs" class="bg-white pt-14 pb-10 sm:pt-16 md:pt-20 md:pb-12 lg:pt-24 lg:pb-14">
      <div class="container mx-auto max-w-[880px] px-4 sm:px-6">
        <div class="animate-reveal mb-7 text-center sm:mb-8 md:mb-10">
          <h2 class="mb-2 font-outfit text-[1.75rem] font-bold leading-tight tracking-[-0.025em] text-deep-navy sm:text-3xl md:text-[2.35rem]">
            Preguntas frecuentes
          </h2>
          <p class="font-outfit text-sm font-semibold text-deep-navy/55 sm:text-base">
            Resolvemos las dudas más comunes sobre Scalo.
          </p>
        </div>
        <FaqAccordion client:visible />
      </div>
    </section>

    <FinalCTA />
  </main>

  <Footer />

  <script>
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) entry.target.classList.add('visible');
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });

    document.querySelectorAll('.animate-reveal').forEach(el => observer.observe(el));
  </script>
</Layout>
