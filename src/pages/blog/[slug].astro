---
import Layout from '../../layouts/Layout.astro';
import NavBar from '../../components/NavBar.astro';
import Footer from '../../components/Footer.astro';
import { getPostBySlug, normalizeUrl } from '../../lib/content-island';

const { slug } = Astro.params;
const post = await getPostBySlug(slug as string);

if (!post) {
  return Astro.redirect('/blog');
}

const { title, excerpt, Body_content, CoverImage, PublishedAt, Author, Category } = post;
const imageUrl = normalizeUrl(CoverImage);
const date = PublishedAt
  ? new Date(PublishedAt).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' })
  : null;

// Inject responsive styles into every <img> tag coming from Content Island HTML
const processedBody = (Body_content ?? '')
  .replace(/\n/g, '<br />')
  .replace(/<img(\s)/gi, '<img style="max-width:100%;height:auto;width:100%;border-radius:1rem;display:block;margin:1.5rem auto;"$1');
---

<Layout title={`${title} — Scalo Blog`} description={excerpt}>
  <NavBar variant="dark" />

  <main class="pt-32 pb-24 min-h-screen">
    <div class="container mx-auto px-6 max-w-3xl">

      <!-- Back link -->
      <a href="/blog" class="article-reveal inline-flex items-center gap-2 text-slate-400 hover:text-white text-sm font-medium mb-10 transition-colors group" style="--delay:0ms">
        <span class="group-hover:-translate-x-1 transition-transform duration-200">←</span> Volver al blog
      </a>

      <!-- Category + date -->
      <div class="article-reveal flex items-center gap-3 mb-5" style="--delay:60ms">
        {Category && (
          <span class="px-3 py-1 bg-scalo-primary/10 border border-scalo-primary/30 text-scalo-primary rounded-full text-xs font-bold uppercase tracking-widest">
            {Category.name}
          </span>
        )}
        {date && <span class="text-slate-500 text-sm">{date}</span>}
      </div>

      <!-- Title -->
      <h1 class="article-reveal text-4xl md:text-6xl font-black text-white leading-[1.05] mb-6 tracking-[-0.03em]" style="--delay:120ms">
        {title}
      </h1>

      <!-- Author -->
      {Author && (
        <div class="flex items-center gap-3 mb-10 pb-10 border-b border-white/10">
          {normalizeUrl(Author.avatar) && (
            <img src={normalizeUrl(Author.avatar)} alt={Author.name}
              class="author-avatar w-10 h-10 rounded-full object-cover border border-white/10 flex-shrink-0" loading="lazy" />
          )}
          <div>
            <p class="text-white font-semibold text-sm">{Author.name}</p>
            {Author.bio && <p class="text-slate-500 text-xs">{Author.bio}</p>}
          </div>
          {Author.LinkedIn && (
            <a href={normalizeUrl(Author.LinkedIn)} target="_blank" rel="noopener noreferrer"
              class="ml-auto text-xs text-slate-400 hover:text-white transition-colors border border-white/10 px-3 py-1 rounded-full">
              LinkedIn →
            </a>
          )}
        </div>
      )}

      <!-- Cover image -->
      {imageUrl && (
        <div class="w-full rounded-2xl overflow-hidden mb-10 border border-white/5">
          <img src={imageUrl} alt={title} class="w-full h-auto object-cover" loading="eager" />
        </div>
      )}

      <!-- Body content -->
      <article class="prose prose-invert prose-slate max-w-none
        prose-headings:font-bold prose-headings:tracking-tight
        prose-a:text-scalo-accent-cyan prose-a:no-underline hover:prose-a:underline
        prose-strong:text-white
        prose-code:text-scalo-accent-violet prose-code:bg-white/5 prose-code:px-1 prose-code:rounded
        prose-img:rounded-2xl prose-img:border prose-img:border-white/10
        prose-img:max-w-full prose-img:h-auto prose-img:w-full
      ">
        <Fragment set:html={processedBody} />
      </article>

    </div>
  </main>

  <Footer />
</Layout>

<style>
  /* Article entrance animations */
  .article-reveal {
    opacity: 0;
    transform: translateY(20px);
    animation: artReveal 0.65s cubic-bezier(0.22, 1, 0.36, 1) forwards;
    animation-delay: var(--delay, 0ms);
  }

  @keyframes artReveal {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Ensure ALL images inside the article fit the container — catches any CI-injected imgs */
  article img {
    max-width: 100% !important;
    height: auto !important;
    width: 100%;
    object-fit: contain;
    border-radius: 1rem;
    display: block;
    margin: 1.5rem auto;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  /* Prevent author avatar from being stretched by the article rule above */
  .author-avatar {
    width: 2.5rem !important;
    height: 2.5rem !important;
    object-fit: cover !important;
    border-radius: 9999px !important;
    margin: 0 !important;
  }

  /* Responsive iframes (YouTube embeds, etc.) */
  article iframe {
    max-width: 100%;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 1rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }
</style>
