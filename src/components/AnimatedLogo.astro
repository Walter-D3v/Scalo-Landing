<style>
.wrap-logo { display:flex; align-items:center; justify-content:center; padding: 2rem 1rem; width: 100%; }
.bar { opacity: 0; transform: translateY(40px); }
.is-visible .bar { animation: slideUp 0.6s cubic-bezier(0.22,1,0.36,1) forwards; }
.is-visible .b1 { animation-delay: 0.1s; }
.is-visible .b2 { animation-delay: 0.35s; }
.is-visible .b3 { animation-delay: 0.6s; }

#txt {
  opacity: 0;
  transition: opacity 1s ease;
  transition-delay: 1.2s;
}
.is-visible #txt {
  opacity: 1;
}

@keyframes slideUp {
  from { opacity:0; transform: translateY(40px); }
  to   { opacity:1; transform: translateY(0); }
}
</style>

