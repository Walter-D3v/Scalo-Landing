---
---
<div id="lead-capture-modal" class="fixed inset-0 z-[100] hidden flex-col items-center justify-center pointer-events-none">
  <!-- Backdrop -->
  <div id="modal-backdrop" class="absolute inset-0 bg-deep-navy/80 backdrop-blur-sm opacity-0 transition-opacity duration-300 pointer-events-none"></div>
  
  <!-- Modal Content -->
  <div id="modal-content" class="glass-card relative z-10 w-full max-w-md p-8 rounded-3xl scale-95 opacity-0 transition-all duration-300 translate-y-4 pointer-events-none mx-4">
    
    <!-- Close Button -->
    <button id="close-modal-btn" aria-label="Cerrar modal" class="absolute top-4 right-4 w-8 h-8 flex items-center justify-center rounded-full bg-white/5 text-slate-400 hover:text-white hover:bg-white/10 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 256 256"><path fill="currentColor" d="M205.66 194.34a8 8 0 0 1-11.32 11.32L128 139.31l-66.34 66.35a8 8 0 0 1-11.32-11.32L116.69 128L50.34 61.66a8 8 0 0 1 11.32-11.32L128 116.69l66.34-66.35a8 8 0 0 1 11.32 11.32L139.31 128Z"/></svg>
    </button>

    <div class="text-center mb-6">
      <div class="w-12 h-12 bg-scalo-primary/20 rounded-2xl mx-auto flex items-center justify-center mb-4">
         <span class="text-2xl">🚀</span>
      </div>
      <h3 class="text-2xl font-bold font-outfit text-white mb-2">Comienza con Scalo</h3>
      <p class="text-slate-400 text-sm">Déjanos tu email y un experto se pondrá en contacto contigo en menos de 24h para activar tu cuenta.</p>
    </div>

    <!-- Form -->
    <form id="lead-form" class="space-y-4" novalidate>
      <div>
        <label for="name" class="block text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">Nombre</label>
        <input 
          type="text" 
          id="name" 
          name="name" 
          required
          placeholder="Tu nombre" 
          aria-label="Tu nombre"
          class="w-full bg-deep-navy/50 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-slate-600 focus:outline-none focus:border-scalo-primary focus:ring-1 focus:ring-scalo-primary transition-all"
        />
      </div>
      
      <div>
        <label for="email" class="block text-xs font-semibold text-slate-400 uppercase tracking-widest mb-1.5 ml-1">Email de Trabajo</label>
        <input 
          type="email" 
          id="email" 
          name="email" 
          required
          placeholder="nombre@empresa.com" 
          aria-label="Correo electrónico corporativo"
          class="w-full bg-deep-navy/50 border border-white/10 rounded-xl px-4 py-3 text-white placeholder-slate-600 focus:outline-none focus:border-scalo-primary focus:ring-1 focus:ring-scalo-primary transition-all"
        />
      </div>

      <button 
        type="submit" 
        class="w-full bg-scalo-primary text-white font-bold py-3.5 rounded-xl hover:shadow-[0_0_20px_rgba(99,102,241,0.4)] transition-all duration-300 mt-2 flex justify-center items-center gap-2 group"
      >
        <span>Solicitar Acceso</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 256 256" class="group-hover:translate-x-1 transition-transform"><path fill="currentColor" d="M221.66 133.66l-72 72a8 8 0 0 1-11.32-11.32L196.69 136H40a8 8 0 0 1 0-16h156.69l-58.35-58.34a8 8 0 0 1 11.32-11.32l72 72a8 8 0 0 1 0 11.32Z"/></svg>
      </button>

      <p class="text-center text-xs text-slate-500 mt-4">Al enviar aceptas nuestros Términos y Condiciones de Privacidad.</p>
    </form>
    
    <!-- Success Message (Hidden by default) -->
    <div id="success-message" class="hidden flex-col items-center justify-center py-6 text-center">
      <div class="w-16 h-16 bg-emerald-500/20 rounded-full flex items-center justify-center text-emerald-400 mb-4 animate-reveal">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 256 256"><path fill="currentColor" d="M173.66 98.34a8 8 0 0 1 0 11.32l-56 56a8 8 0 0 1-11.32 0l-24-24a8 8 0 0 1 11.32-11.32L112 148.69l50.34-50.35a8 8 0 0 1 11.32 0ZM224 128a96 96 0 1 1-96-96a96.11 96.11 0 0 1 96 96Zm-16 0a80 80 0 1 0-80 80a80.09 80.09 0 0 0 80-80Z"/></svg>
      </div>
      <h3 class="text-xl font-bold text-white mb-2">¡Solicitud Recibida!</h3>
      <p class="text-slate-400 text-sm">Revisa tu bandeja de entrada pronto. Hemos enviado los detalles.</p>
    </div>
  </div>
</div>

<script>
  const leadModal = document.getElementById('lead-capture-modal');
  const backdrop = document.getElementById('modal-backdrop');
  const content = document.getElementById('modal-content');
  const closeBtn = document.getElementById('close-modal-btn');
  const form = document.getElementById('lead-form');
  const successMessage = document.getElementById('success-message');
  
  // Expose function globally to be called from other components
  window.openLeadModal = () => {
    if(!leadModal || !backdrop || !content) return;
    
    leadModal.classList.remove('hidden');
    leadModal.classList.add('flex');
    
    // Enable pointer events
    leadModal.classList.remove('pointer-events-none');
    backdrop.classList.remove('pointer-events-none');
    content.classList.remove('pointer-events-none');
    
    // Trigger animations
    setTimeout(() => {
      backdrop.classList.remove('opacity-0');
      backdrop.classList.add('opacity-100');
      
      content.classList.remove('opacity-0', 'scale-95', 'translate-y-4');
      content.classList.add('opacity-100', 'scale-100', 'translate-y-0');
    }, 10);
    
    // Lock body scroll (optional, but good practice)
    document.body.style.overflow = 'hidden';
  };

  const closeModal = () => {
    if(!leadModal || !backdrop || !content) return;
    
    backdrop.classList.remove('opacity-100');
    backdrop.classList.add('opacity-0');
    
    content.classList.remove('opacity-100', 'scale-100', 'translate-y-0');
    content.classList.add('opacity-0', 'scale-95', 'translate-y-4');
    
    // Disable pointer events immediately
    leadModal.classList.add('pointer-events-none');
    
    setTimeout(() => {
      leadModal.classList.add('hidden');
      leadModal.classList.remove('flex');
      document.body.style.overflow = '';
      
      // Reset form state on close
      setTimeout(() => {
         if(form && successMessage) {
            form.style.display = 'block';
            successMessage.classList.add('hidden');
            successMessage.classList.remove('flex');
            (form as HTMLFormElement).reset();
         }
      }, 300);
    }, 300);
  };

  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  // Form submission mock
  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    if((form as HTMLFormElement).checkValidity()) {
        form.style.display = 'none';
        successMessage?.classList.remove('hidden');
        successMessage?.classList.add('flex');
        
        // Auto close after 3 seconds
        setTimeout(closeModal, 3000);
    } else {
        // Simple visual feedback for invalid form
        form.classList.add('animate-pulse');
        setTimeout(() => form.classList.remove('animate-pulse'), 500);
    }
  });
  
  // Expose globally for TypeScript
  declare global {
    interface Window {
      openLeadModal: () => void;
    }
  }
</script>
