---
export interface Feature {
  icon: string;
  title: string;
  description: string;
  badge?: string;
}

export interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  features: Feature[];
}

const { title, subtitle, description, features } = Astro.props as Props;
---

<section id="features" class="py-16 md:py-24 px-4 md:px-8 relative overflow-hidden">
  <!-- Radial gradient background replaced via absolute div -->
  <div class="absolute -top-1/2 -right-1/5 w-[600px] h-[600px] rounded-full bg-[radial-gradient(circle,rgba(168,85,247,0.1)_0%,transparent_70%)] pointer-events-none"></div>

  <div class="container mx-auto">
    <div class="text-center mb-16 relative z-10 reveal">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4">{title}</h2>
      {subtitle && <p class="text-xl mb-4 bg-clip-text text-transparent bg-gradient-to-r from-scalo-primary to-scalo-accent-purple font-semibold">{subtitle}</p>}
      {description && <p class="text-base text-slate-400 max-w-2xl mx-auto">{description}</p>}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 relative z-10">
      {features.map((feature, index) => (
        <div 
          class="glass p-8 flex flex-col gap-4 rounded-2xl relative overflow-hidden transition-all duration-300 border border-white/5 hover:border-scalo-primary/40 hover:shadow-[0_0_40px_rgba(99,102,241,0.2)] hover:bg-gradient-to-br hover:from-scalo-primary/10 hover:to-scalo-accent-purple/10 group reveal group" 
          style={`animation-delay: ${index * 0.1}s`}
        >
          <!-- Hover effect overlay -->
          <div class="absolute inset-0 bg-gradient-to-br from-transparent to-scalo-primary/10 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          
          <div class="text-4xl w-[60px] h-[60px] flex items-center justify-center bg-gradient-to-br from-scalo-primary/20 to-scalo-accent-purple/15 rounded-xl border border-scalo-primary/30 z-10 relative">
            {feature.icon}
          </div>
          <h3 class="text-xl font-bold text-white z-10 relative">{feature.title}</h3>
          <p class="text-[0.95rem] text-slate-400 leading-relaxed z-10 relative">{feature.description}</p>
          {feature.badge && (
            <span class="self-start mt-2 px-3 py-1 rounded-full text-xs font-semibold bg-scalo-primary/20 text-scalo-accent-cyan border border-scalo-primary/30 z-10 relative">
              {feature.badge}
            </span>
          )}
        </div>
      ))}
    </div>
  </div>
</section>

