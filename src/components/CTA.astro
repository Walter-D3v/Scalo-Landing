---
export interface Props {
  title: string;
  description: string;
  ctaText?: string;
}

const { title, description, ctaText = "Comenzar prueba gratis" } = Astro.props as Props;
---

<section id="cta" class="cta">
  <div class="cta-blur blur-1"></div>
  <div class="cta-blur blur-2"></div>
  
  <div class="container cta-content">
    <div class="cta-text reveal">
      <h2 class="cta-title">{title}</h2>
      <p class="cta-description">{description}</p>
    </div>

    <button class="btn btn-primary btn-large reveal" style="animation-delay: 0.2s">
      <span class="icon">🚀</span>
      {ctaText}
    </button>
  </div>
</section>

<style>
  .cta {
    padding: 6rem 2rem;
    position: relative;
    overflow: hidden;
    border-top: 1px solid var(--glass-light);
  }

  .cta-blur {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(60px);
  }

  .blur-1 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(99, 102, 241, 0.2) 0%, transparent 70%);
    top: -200px;
    left: -200px;
  }

  .blur-2 {
    width: 400px;
    height: 400px;
    background: radial-gradient(circle, rgba(168, 85, 247, 0.15) 0%, transparent 70%);
    bottom: -200px;
    right: -200px;
  }

  .cta-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2rem;
    text-align: center;
    z-index: 1;
    position: relative;
  }

  .cta-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 700px;
  }

  .cta-title {
    font-size: clamp(2rem, 5vw, 3.5rem);
    background: linear-gradient(135deg, #f8fafc 0%, #cbd5e1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .cta-description {
    font-size: 1.125rem;
    color: var(--text-secondary);
    line-height: 1.8;
  }

  .btn-large {
    padding: 16px 40px;
    font-size: 1.1rem;
  }

  @media (max-width: 768px) {
    .cta {
      padding: 4rem 1rem;
    }

    .btn-large {
      width: 100%;
      justify-content: center;
    }
  }
</style>
