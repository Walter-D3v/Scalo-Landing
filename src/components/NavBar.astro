---
interface Props {
  variant?: 'light' | 'dark';
}

const { variant = 'light' } = Astro.props;

const navLinks = [
  { name: 'Inicio', href: '/#inicio', id: 'inicio' },
  { name: 'Producto', href: '/#producto', id: 'producto' },
  { name: 'Acerca', href: '/#como-funciona', id: 'como-funciona' },
  { name: 'Precio', href: '/#faqs', id: 'faqs' },
  { name: 'Contacto', href: '/#contacto', id: 'contacto' },
];
---

<header
  id="main-header"
  class="pointer-events-none fixed top-0 left-0 z-50 flex w-full justify-center px-4 pt-5 transition-all duration-500 ease-out md:px-6"
>
  <nav
    id="main-nav"
    class:list={[
      'pointer-events-auto flex w-full max-w-[1280px] items-center justify-between gap-4 transition-all duration-500 ease-out',
      variant === 'light'
        ? 'rounded-full border border-black/[0.04] bg-white px-6 py-3 md:px-8 md:py-3'
        : 'glass rounded-full border border-white/10 px-8 py-3',
    ]}
  >
    <a href="/" class="group flex shrink-0 items-center" aria-label="Volver al inicio">
      <img
        id="nav-logo"
        src={variant === 'light' ? '/images/home/logo-color-nav.png' : '/Scalo-logoWhite.png'}
        alt="Scalo"
        class="h-5 w-auto transition-all duration-500 group-hover:opacity-90 md:h-[22px] lg:h-6"
      />
    </a>

    <div id="nav-right" class="hidden items-center gap-3 md:flex lg:gap-6 xl:gap-8">
      <ul id="nav-links" class="flex items-center gap-0.5 lg:gap-1 xl:gap-2" role="menubar">
        {navLinks.map((link) => (
          <li role="none">
            <a
              href={link.href}
              role="menuitem"
              data-section={link.id}
              class:list={[
                'nav-link rounded-full px-3 py-2 font-outfit text-[13px] font-medium tracking-wide transition-all duration-200 focus:outline-none focus:ring-2 focus:ring-scalo-primary/40 md:px-3.5 lg:px-4 lg:text-[15px]',
                variant === 'light'
                  ? 'text-deep-navy/75 hover:text-deep-navy'
                  : 'text-slate-400 hover:text-white',
              ]}
            >
              {link.name}
            </a>
          </li>
        ))}
      </ul>

      <a
        href="/waitlist"
        id="nav-cta"
        class="btn-scalo-primary shrink-0 whitespace-nowrap px-4 py-2 text-xs font-bold md:px-5 md:py-2.5 md:text-sm lg:px-7 lg:text-[15px]"
      >
        Acceso anticipado
      </a>
    </div>

    <button
      id="mobile-menu-btn"
      class="z-30 flex h-11 w-11 flex-col items-center justify-center gap-1.5 rounded-full focus:outline-none focus:ring-2 focus:ring-scalo-primary/30 md:hidden"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span class:list={['h-0.5 w-6 origin-center transition-all duration-300', variant === 'light' ? 'bg-deep-navy' : 'bg-white']} id="line1"></span>
      <span class:list={['h-0.5 w-6 origin-center transition-all duration-200', variant === 'light' ? 'bg-deep-navy' : 'bg-white']} id="line2"></span>
      <span class:list={['h-0.5 w-6 origin-center transition-all duration-300', variant === 'light' ? 'bg-deep-navy' : 'bg-white']} id="line3"></span>
    </button>
  </nav>

  <div
    id="mobile-menu-backdrop"
    class="pointer-events-none fixed inset-0 z-[5] bg-deep-navy/20 opacity-0 backdrop-blur-[2px] transition-opacity duration-300 md:hidden"
    aria-hidden="true"
  ></div>

  <div
    id="mobile-menu-drawer"
    class:list={[
      'pointer-events-none absolute top-2 z-10 flex max-h-[calc(100dvh-5rem)] w-[calc(100%-2rem)] max-w-[1280px] -translate-y-[120%] flex-col gap-6 overflow-y-auto rounded-3xl p-6 pb-8 pt-20 opacity-0 shadow-2xl transition-all duration-500 origin-top md:hidden',
      variant === 'light' ? 'border border-black/5 bg-white' : 'glass border border-white/10',
    ]}
  >
    <ul class="flex flex-col items-center gap-6">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="mobile-link font-outfit text-xl font-bold text-deep-navy/80 transition-colors hover:text-scalo-primary">
            {link.name}
          </a>
        </li>
      ))}
      <li>
        <a href="/waitlist" class="mobile-link btn-scalo-primary mt-2 inline-block px-8 py-3 text-base">
          Acceso anticipado
        </a>
      </li>
    </ul>
  </div>
</header>

<style>
  .nav-link.is-active {
    background: var(--color-scalo-primary-50);
    color: var(--color-deep-navy);
    font-weight: 600;
  }
</style>

<script>
  const header = document.getElementById('main-header')!;
  const nav = document.getElementById('main-nav')!;
  const navLinkItems = document.querySelectorAll<HTMLAnchorElement>('.nav-link');

  let isScrolled = false;

  function setActiveLink(activeId: string) {
    navLinkItems.forEach((link) => {
      const isActive = link.dataset.section === activeId;
      link.classList.toggle('is-active', isActive);
    });
  }

  // Figma: al scroll el menú se encoge horizontalmente en pill flotante (solo desktop)
  function applyScrollState(scrolled: boolean) {
    const isDesktop = window.matchMedia('(min-width: 1024px)').matches;

    if (scrolled && isDesktop) {
      header.classList.remove('px-4', 'md:px-6');
      header.classList.add('px-8', 'md:px-14', 'lg:px-20');

      nav.classList.remove('max-w-[1280px]');
      nav.classList.add('max-w-[900px]');
    } else {
      header.classList.add('px-4', 'md:px-6');
      header.classList.remove('px-8', 'md:px-14', 'lg:px-20');

      nav.classList.add('max-w-[1280px]');
      nav.classList.remove('max-w-[900px]');
    }
  }

  window.addEventListener(
    'scroll',
    () => {
      const shouldBeScrolled = window.scrollY > 40;
      if (shouldBeScrolled !== isScrolled) {
        isScrolled = shouldBeScrolled;
        applyScrollState(isScrolled);
      }
    },
    { passive: true }
  );

  applyScrollState(window.scrollY > 40);
  window.addEventListener('resize', () => applyScrollState(isScrolled), { passive: true });

  const sections = ['inicio', 'producto', 'como-funciona', 'faqs', 'contacto'];
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          setActiveLink(entry.target.id);
        }
      });
    },
    { rootMargin: '-40% 0px -50% 0px', threshold: 0 }
  );

  sections.forEach((id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });

  if (window.scrollY < 100) {
    setActiveLink('inicio');
  }

  const mobileBtn = document.getElementById('mobile-menu-btn')!;
  const mobileBackdrop = document.getElementById('mobile-menu-backdrop')!;
  const mobileDrawer = document.getElementById('mobile-menu-drawer')!;
  const line1 = document.getElementById('line1')!;
  const line2 = document.getElementById('line2')!;
  const line3 = document.getElementById('line3')!;
  const mobileLinks = document.querySelectorAll('.mobile-link');

  let menuOpen = false;

  const toggleMenu = () => {
    menuOpen = !menuOpen;
    mobileBtn.setAttribute('aria-expanded', menuOpen.toString());

    if (menuOpen) {
      mobileBackdrop.classList.remove('opacity-0', 'pointer-events-none');
      mobileBackdrop.classList.add('opacity-100', 'pointer-events-auto');
      mobileDrawer.classList.remove('-translate-y-[120%]', 'opacity-0', 'pointer-events-none');
      mobileDrawer.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');
      line1.classList.add('translate-y-2', 'rotate-45');
      line2.classList.add('opacity-0');
      line3.classList.add('-translate-y-2', '-rotate-45');
      document.body.style.overflow = 'hidden';
    } else {
      mobileBackdrop.classList.add('opacity-0', 'pointer-events-none');
      mobileBackdrop.classList.remove('opacity-100', 'pointer-events-auto');
      mobileDrawer.classList.add('-translate-y-[120%]', 'opacity-0', 'pointer-events-none');
      mobileDrawer.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
      line1.classList.remove('translate-y-2', 'rotate-45');
      line2.classList.remove('opacity-0');
      line3.classList.remove('-translate-y-2', '-rotate-45');
      document.body.style.overflow = '';
    }
  };

  mobileBtn.addEventListener('click', toggleMenu);
  mobileBackdrop.addEventListener('click', toggleMenu);
  mobileLinks.forEach((link) => link.addEventListener('click', () => { if (menuOpen) toggleMenu(); }));
</script>
