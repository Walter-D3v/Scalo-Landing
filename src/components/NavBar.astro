---
import { getLandingSectionsConfig } from '../lib/content-island';

const sectionsConfig = await getLandingSectionsConfig();

const getBool = (config: any, fieldName: string): boolean => {
  if (!config) return true;
  const lower = fieldName.toLowerCase();
  if (typeof config[fieldName] === 'boolean') return config[fieldName];
  if (typeof config[lower] === 'boolean') return config[lower];
  if (typeof config.fields?.[fieldName] === 'boolean') return config.fields[fieldName];
  if (typeof config.fields?.[lower] === 'boolean') return config.fields[lower];
  return true;
};

const showProblem = getBool(sectionsConfig, 'ProblemSection');
const showFeatures = getBool(sectionsConfig, 'Features');
const showHowItWorks = getBool(sectionsConfig, 'HowItWorks');
const showTestimonials = getBool(sectionsConfig, 'Testimonials');
const showBlog = getBool(sectionsConfig, 'Blog');

const navLinks = [
  ...(showProblem ? [{ name: 'Por qué Scalo', href: '/#problema' }] : []),
  ...(showFeatures ? [{ name: 'Features', href: '/#features' }] : []),
  ...(showHowItWorks ? [{ name: 'Cómo funciona', href: '/#como-funciona' }] : []),
  ...(showTestimonials ? [{ name: 'Soluciones', href: '/#soluciones' }] : []),
  ...(showBlog ? [{ name: 'Blog', href: '/blog' }] : []),
];
---

<!--
  Estado inicial  → barra completa ancho full, py-4
  Tras scroll >40 → isla flotante centrada, compacta, pill shape
-->
<header
  id="main-header"
  class="fixed top-0 left-0 w-full z-50 flex justify-center px-4 pt-4 transition-all duration-500 pointer-events-none"
>
  <nav
    id="main-nav"
    class="
      w-full max-w-7xl
      glass px-6 py-3 rounded-2xl
      flex items-center
      border border-white/5
      transition-all duration-500
      pointer-events-auto
    "
  >
    <!-- Logo -->
    <div class="flex-1 flex justify-start">
      <a href="/" class="flex items-center gap-2 group flex-shrink-0" aria-label="Volver al inicio">
      <img
        id="nav-logo"
        src="/Scalo-logoWhite.png"
        alt="Scalo"
        class="h-10 w-auto group-hover:scale-105 transition-all duration-500"
      />
      </a>
    </div>

    <!-- Desktop Nav -->
    <ul id="nav-links" class="hidden md:flex flex-none items-center justify-center gap-8 transition-all duration-500" role="menubar">
      {navLinks.map((link) => (
        <li role="none">
          <a
            href={link.href}
            role="menuitem"
            class="text-slate-400 hover:text-white font-medium transition-colors duration-200 text-sm tracking-wide focus:outline-none focus:ring-2 focus:ring-scalo-primary rounded-md px-2 py-1"
          >
            {link.name}
          </a>
        </li>
      ))}
    </ul>

    <!-- Actions (Right) -->
    <div class="flex-1 flex justify-end items-center gap-4">
      <!-- CTA Button -->
      <a 
        href="/waitlist" 
        class="hidden md:flex bg-scalo-accent-violet hover:bg-scalo-accent-violet/90 text-white font-bold py-2 px-5 rounded-full text-sm transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_5px_20px_-5px_rgba(139,92,246,0.6)]"
      >
        Private Testing
      </a>
      
      <!-- Mobile Menu Toggle -->
      <button
      id="mobile-menu-btn"
      class="md:hidden w-10 h-10 flex flex-col items-center justify-center gap-1.5 focus:outline-none z-30"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <span class="w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="line1"></span>
      <span class="w-6 h-0.5 bg-white transition-all duration-200 origin-center" id="line2"></span>
      <span class="w-6 h-0.5 bg-white transition-all duration-300 origin-center" id="line3"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu Drawer -->
  <div
    id="mobile-menu-drawer"
    class="absolute top-2 w-[calc(100%-2rem)] glass rounded-3xl p-6 pt-24 -translate-y-[120%] opacity-0 transition-all duration-500 z-10 flex flex-col gap-6 shadow-2xl border border-white/10 pointer-events-none pb-8 text-center origin-top"
  >
    <ul class="flex flex-col gap-6 items-center">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="mobile-link text-xl text-slate-300 hover:text-white font-bold transition-colors font-outfit uppercase tracking-wider"
          >
            {link.name}
          </a>
        </li>
      ))}
      <li>
        <a
          href="/waitlist"
          class="mobile-link text-xl text-scalo-accent-violet hover:text-white font-bold transition-colors font-outfit uppercase tracking-wider mt-4 inline-block border border-scalo-accent-violet/50 px-6 py-2 rounded-full"
        >
          Private Testing
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  const header   = document.getElementById('main-header')!;
  const nav      = document.getElementById('main-nav')!;
  const logo     = document.getElementById('nav-logo') as HTMLImageElement;
  const navLinks = document.getElementById('nav-links')!;



  let isScrolled = false;

  function applyScrollState(scrolled: boolean) {
    if (scrolled) {
      // ── Isla compacta (~65% del ancho) ────────────────────────────
      nav.classList.remove('w-full', 'max-w-7xl', 'rounded-2xl', 'px-6', 'py-3', 'border-white/5');
      nav.classList.add('rounded-full', 'px-5', 'py-2', 'shadow-2xl', 'shadow-black/40', 'border-white/10');
      nav.style.maxWidth = '780px';
      nav.style.width    = 'calc(100% - 2rem)';

      // Logo más pequeño
      logo.classList.remove('h-10');
      logo.classList.add('h-7');

      // Links: fuente un poco más chica
      navLinks.classList.add('gap-5');
      navLinks.classList.remove('gap-8');

      // CTA: compactar padding en isla

      header.classList.replace('pt-4', 'pt-3');
    } else {
      // ── Barra completa ────────────────────────────────────────────
      nav.classList.add('w-full', 'max-w-7xl', 'rounded-2xl', 'px-6', 'py-3', 'border-white/5');
      nav.classList.remove('rounded-full', 'px-5', 'py-2', 'shadow-2xl', 'shadow-black/40', 'border-white/10');
      nav.style.maxWidth = '';
      nav.style.width    = '';

      logo.classList.replace('h-7', 'h-10');

      navLinks.classList.replace('gap-5', 'gap-8');



      header.classList.replace('pt-3', 'pt-4');
    }
  }

  window.addEventListener('scroll', () => {
    const shouldBeScrolled = window.scrollY > 40;
    if (shouldBeScrolled !== isScrolled) {
      isScrolled = shouldBeScrolled;
      applyScrollState(isScrolled);
    }
  }, { passive: true });

  // ── Mobile menu ──────────────────────────────────────────────────
  const mobileBtn    = document.getElementById('mobile-menu-btn')!;
  const mobileDrawer = document.getElementById('mobile-menu-drawer')!;
  const line1        = document.getElementById('line1')!;
  const line2        = document.getElementById('line2')!;
  const line3        = document.getElementById('line3')!;
  const mobileLinks  = document.querySelectorAll('.mobile-link');

  let menuOpen = false;

  const toggleMenu = () => {
    menuOpen = !menuOpen;
    mobileBtn.setAttribute('aria-expanded', menuOpen.toString());

    if (menuOpen) {
      mobileDrawer.classList.remove('-translate-y-[120%]', 'opacity-0', 'pointer-events-none');
      mobileDrawer.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');
      line1.classList.add('translate-y-2', 'rotate-45');
      line2.classList.add('opacity-0');
      line3.classList.add('-translate-y-2', '-rotate-45');
      document.body.style.overflow = 'hidden';
    } else {
      mobileDrawer.classList.add('-translate-y-[120%]', 'opacity-0', 'pointer-events-none');
      mobileDrawer.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
      line1.classList.remove('translate-y-2', 'rotate-45');
      line2.classList.remove('opacity-0');
      line3.classList.remove('-translate-y-2', '-rotate-45');
      document.body.style.overflow = '';
    }
  };

  mobileBtn.addEventListener('click', toggleMenu);
  mobileLinks.forEach(link => link.addEventListener('click', () => { if (menuOpen) toggleMenu(); }));
</script>
