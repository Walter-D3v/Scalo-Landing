<section id="inicio" class="relative overflow-hidden bg-hero-linen pt-24 pb-10 sm:pt-28 sm:pb-12 md:pt-36 md:pb-20">
  <div class="container mx-auto max-w-7xl px-4 sm:px-6">
    <div class="glass-panel relative rounded-[24px] p-5 shadow-[inset_0_1px_0_rgba(255,255,255,0.6)] sm:rounded-[32px] sm:p-6 md:rounded-[50px] md:p-10 lg:p-14">
      <div class="grid items-center gap-8 sm:gap-10 lg:grid-cols-2 lg:gap-12 xl:gap-16">
        <div class="animate-reveal space-y-5 sm:space-y-6 md:space-y-8" style="transition-delay: 0.1s">
          <h1 class="font-outfit text-[1.75rem] font-bold leading-[1.08] tracking-tight text-deep-navy sm:text-4xl md:text-5xl lg:text-[3.25rem]">
            Los datos no escalan empresas, las decisiones sí.
          </h1>
          <p class="max-w-xl font-outfit text-[15px] font-normal leading-relaxed text-deep-navy/65 sm:text-lg md:text-xl">
            Scalo convierte la información de tu empresa en decisiones concretas. Sin reportes que nadie lee. Sin consultores caros. Sin tener que ser experto en datos.
          </p>
          <a
            href="/waitlist"
            class="btn-scalo-primary inline-flex h-[44px] w-full items-center justify-center px-5 text-sm tracking-wide sm:h-[46px] sm:w-auto sm:px-6 sm:text-base md:h-[50px] md:px-7 md:text-lg"
          >
            Acceso anticipado
          </a>
        </div>

        <div class="relative animate-reveal overflow-visible lg:pl-4" style="transition-delay: 0.25s">
          <div class="origin-center scale-[1.25] animate-float">
            <img
              src="/images/home/Visual%20Mockup%20SCALO.png"
              alt="Dashboard de Scalo en tablet"
              class="w-full h-auto max-w-full object-contain drop-shadow-[0_20px_50px_rgba(16,14,50,0.15)]"
              loading="eager"
              width="5760"
              height="3240"
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
