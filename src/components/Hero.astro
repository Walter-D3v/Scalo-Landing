          </p>
          <a
            href="/waitlist"
            class="btn-scalo-primary inline-flex h-[48px] w-full items-center justify-center px-6 text-base tracking-wide sm:h-[52px] sm:w-auto sm:px-8 sm:text-lg md:h-[59px] md:text-xl lg:text-2xl"
          >
            Acceso anticipado
          </a>
        </div>

        <div class="relative animate-reveal lg:pl-4" style="transition-delay: 0.25s">
          <img
            src="/images/home/mockup.png"
            alt="Dashboard de Scalo en tablet"
            class="w-full h-auto object-contain drop-shadow-[0_20px_50px_rgba(16,14,50,0.15)] animate-float"
            loading="eager"
            width="669"
            height="521"
          />
        </div>
      </div>
    </div>
  </div>
</section>
