---
---

<section class="py-10 md:py-14 lg:py-16 bg-gradient-to-b from-white-linen via-white to-white">
  <div class="container mx-auto px-6 max-w-[1284px]">
    <div
      class="cta-band relative overflow-hidden rounded-[32px] md:rounded-[48px] lg:rounded-[64px] flex items-center justify-center animate-reveal"
    >
      <img
        src="/images/home/cta-band.png"
        alt=""
        class="absolute inset-0 w-full h-full object-cover object-center"
        aria-hidden="true"
        width="2880"
        height="802"
      />

      <div class="relative z-10 max-w-[920px] px-5 py-12 text-center sm:px-6 sm:py-14 md:px-12 md:py-16 lg:py-[72px]">
        <h2
          class="animate-reveal mb-7 font-outfit text-[1.45rem] font-bold leading-[1.18] tracking-tight text-deep-navy sm:mb-8 sm:text-[1.85rem] md:mb-10 md:text-[2.35rem] lg:text-[2.5rem]"
        >
          No construimos Scalo en una sala de reuniones,<br class="hidden sm:block" />
          lo construimos con empresas reales.
        </h2>
        <a
          href="/waitlist"
          class="btn-scalo-primary animate-reveal inline-flex h-[48px] w-full items-center justify-center px-6 text-base tracking-wide sm:h-[52px] sm:w-auto sm:px-8 sm:text-lg md:h-[59px] md:px-10 md:text-xl"
          style="transition-delay: 0.15s"
        >
          Quiero formar parte
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-band {
    min-height: 260px;
    box-shadow: 0 4px 24px rgba(93, 73, 246, 0.08);
  }

  @media (min-width: 768px) {
    .cta-band {
      min-height: 300px;
    }
  }

  @media (min-width: 1024px) {
    .cta-band {
      min-height: 320px;
      aspect-ratio: 2880 / 802;
    }
  }
</style>
