---
export interface Props {
  title?: string;
  subtitle?: string;
  navItems?: Array<{ label: string; href: string }>;
}

const { 
  title = "ScaloAI",
  navItems = [
    { label: "Features", href: "#features" },
    { label: "How it Works", href: "#how" },
    { label: "Pricing", href: "#pricing" },
    { label: "Testimonials", href: "#testimonials" }
  ]
} = Astro.props as Props;
---

<header class="header glass">
  <nav class="nav-wrapper">
    <div class="nav-container">
      <a href="#hero" class="logo">
        <span class="logo-icon">◆</span>
        <span class="logo-text">{title}</span>
      </a>
      
      <ul class="nav-links">
        {navItems.map((item) => (
          <li>
            <a href={item.href} class="nav-link">{item.label}</a>
          </li>
        ))}
      </ul>
      
      <div class="nav-actions">
        <button class="btn btn-secondary" onclick="switchTheme()">
          <span class="icon">☀️</span>
        </button>
        <a href="#pricing" class="btn btn-primary">
          Empezar ahora
        </a>
      </div>

      <button class="mobile-menu-toggle" id="mobileMenuToggle" aria-label="Toggle menu">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </nav>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 1000;
    margin-bottom: 2rem;
  }

  .nav-wrapper {
    padding: 1rem 0;
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--text-primary);
    transition: all var(--transition-fast);
  }

  .logo-icon {
    display: inline-block;
    background: linear-gradient(135deg, var(--accent-cyan) 0%, var(--primary-light) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    animation: rotate 20s linear infinite;
  }

  @keyframes rotate {
    0%, 100% { transform: rotate(0deg); }
    50% { transform: rotate(180deg); }
  }

  .nav-links {
    display: flex;
    list-style: none;
    gap: 2rem;
    align-items: center;
  }

  .nav-link {
    color: var(--text-secondary);
    text-decoration: none;
    font-weight: 500;
    transition: all var(--transition-fast);
    position: relative;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent-cyan), var(--primary-light));
    transition: width var(--transition-fast);
  }

  .nav-link:hover {
    color: var(--text-primary);
  }

  .nav-link:hover::after {
    width: 100%;
  }

  .nav-actions {
    display: flex;
    gap: 1rem;
    align-items: center;
  }

  .mobile-menu-toggle {
    display: none;
    flex-direction: column;
    gap: 0.4rem;
    background: none;
    border: none;
    cursor: pointer;
  }

  .mobile-menu-toggle span {
    width: 24px;
    height: 2.5px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: all var(--transition-fast);
  }

  @media (max-width: 768px) {
    .nav-container {
      gap: 1rem;
    }

    .nav-links {
      gap: 1rem;
      font-size: 0.95rem;
    }

    .mobile-menu-toggle {
      display: flex;
    }

    .nav-actions {
      flex-direction: column;
      gap: 0.5rem;
    }

    .nav-actions .btn {
      padding: 10px 16px;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }

    .nav-container {
      padding: 0 1rem;
    }
  }
</style>

<script>
  function switchTheme() {
    const isDark = document.documentElement.style.colorScheme === 'dark';
    document.documentElement.style.colorScheme = isDark ? 'light' : 'dark';
  }

  const toggle = document.getElementById('mobileMenuToggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const nav = document.querySelector('.nav-links') as HTMLElement | null;
      if (nav) {
        nav.style.display = nav.style.display === 'flex' ? 'none' : 'flex';
      }
    });
  }
</script>
