---
export interface Props {
  title?: string;
  subtitle?: string;
  navItems?: Array<{ label: string; href: string }>;
}

const { 
  title = "ScaloAI",
  navItems = [
    { label: "Features", href: "#features" },
    { label: "How it Works", href: "#how" },
    { label: "Pricing", href: "#pricing" },
    { label: "Testimonials", href: "#testimonials" }
  ]
} = Astro.props as Props;
---

<header class="sticky top-0 z-[1000] mb-8 glass">
  <nav class="py-4">
    <div class="flex items-center justify-between gap-4 md:gap-8 max-w-[1200px] mx-auto px-4 md:px-6">
      <a href="#hero" class="flex items-center gap-2 text-xl font-bold text-white no-underline transition-all duration-200 hover:opacity-80">
        <img src="/Scalo-logoWhite.png" alt="Scalo" class="h-10 w-auto" />
      </a>
      
      <ul class="hidden sm:flex list-none gap-4 md:gap-8 items-center text-[0.95rem] md:text-base nav-links">
        {navItems.map((item) => (
          <li>
            <a 
              href={item.href} 
              class="text-slate-400 no-underline font-medium transition-colors duration-200 relative group hover:text-white"
            >
              {item.label}
              <span class="absolute -bottom-1 left-0 w-0 h-[2px] bg-gradient-to-r from-scalo-accent-cyan to-scalo-primary-light transition-all duration-200 group-hover:w-full"></span>
            </a>
          </li>
        ))}
      </ul>
      
      <div class="flex flex-col sm:flex-row gap-2 sm:gap-4 items-center">
        <button class="p-2.5 rounded-xl bg-white/5 border border-white/10 hover:bg-white/10 transition-colors text-sm sm:text-base hidden sm:block" onclick="switchTheme()" aria-label="Toggle Theme">
          <span>☀️</span>
        </button>
        <a href="#pricing" class="px-4 py-2 sm:px-6 sm:py-3 rounded-xl bg-scalo-primary text-white font-bold text-sm sm:text-base hover:bg-scalo-primary-light transition-colors shadow-lg shadow-scalo-primary/20">
          Empezar ahora
        </a>
      </div>

      <button class="flex sm:hidden flex-col gap-1.5 bg-transparent border-none cursor-pointer" id="mobileMenuToggle" aria-label="Toggle menu">
        <span class="w-6 h-[2.5px] bg-white rounded-sm transition-all duration-200"></span>
        <span class="w-6 h-[2.5px] bg-white rounded-sm transition-all duration-200"></span>
        <span class="w-6 h-[2.5px] bg-white rounded-sm transition-all duration-200"></span>
      </button>
    </div>
  </nav>
</header>

<script>
  function switchTheme() {
    const isDark = document.documentElement.style.colorScheme === 'dark';
    document.documentElement.style.colorScheme = isDark ? 'light' : 'dark';
  }

  const toggle = document.getElementById('mobileMenuToggle');
  if (toggle) {
    toggle.addEventListener('click', () => {
      const nav = document.querySelector('.nav-links') as HTMLElement | null;
      if (nav) {
        if (nav.classList.contains('hidden')) {
          nav.classList.remove('hidden');
          nav.classList.add('flex', 'flex-col', 'absolute', 'top-full', 'left-0', 'w-full', 'glass', 'p-4', 'gap-4');
        } else {
          nav.classList.add('hidden');
          nav.classList.remove('flex', 'flex-col', 'absolute', 'top-full', 'left-0', 'w-full', 'glass', 'p-4', 'gap-4');
        }
      }
    });
  }
</script>
