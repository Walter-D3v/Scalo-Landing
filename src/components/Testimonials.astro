---
export interface Testimonial {
  text: string;
  author: string;
  role: string;
  company: string;
  avatar: string;
  rating?: number;
}

export interface Props {
  title: string;
  subtitle?: string;
  testimonials: Testimonial[];
}

const { title, subtitle, testimonials } = Astro.props as Props;
---

<section id="testimonials" class="py-16 md:py-24 px-4 md:px-8 relative overflow-hidden">
  <!-- Radial Gradient Background -->
  <div class="absolute -top-[20%] -right-[10%] w-[500px] h-[500px] rounded-full bg-[radial-gradient(circle,rgba(236,72,153,0.08)_0%,transparent_70%)] pointer-events-none"></div>

  <div class="container mx-auto">
    <div class="text-center mb-16 relative z-10 reveal">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4">{title}</h2>
      {subtitle && <p class="text-xl mb-4 bg-clip-text text-transparent bg-gradient-to-r from-scalo-accent-purple to-scalo-accent-pink font-semibold">{subtitle}</p>}
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 relative z-10">
      {testimonials.map((testimonial, index) => (
        <div 
          class="glass p-8 flex flex-col gap-6 border border-white/10 rounded-2xl transition-all duration-300 hover:border-scalo-accent-pink/50 hover:shadow-[0_0_30px_rgba(236,72,153,0.15)] hover:-translate-y-2 reveal" 
          style={`animation-delay: ${index * 0.1}s`}
        >
          {testimonial.rating && (
            <div class="text-lg tracking-widest text-yellow-400">
              {'⭐'.repeat(testimonial.rating)}
            </div>
          )}
          <p class="text-base leading-relaxed text-slate-300 italic">"{testimonial.text}"</p>
          <div class="flex gap-4 items-start mt-auto">
            <div class="w-12 h-12 rounded-full bg-gradient-to-br from-scalo-accent-cyan to-scalo-primary-light flex items-center justify-center font-bold text-sm text-deep-navy shrink-0">
              {testimonial.avatar}
            </div>
            <div class="flex flex-col gap-1">
              <p class="font-bold text-white text-[0.95rem]">{testimonial.author}</p>
              <p class="text-[0.85rem] text-slate-400">
                {testimonial.role} • {testimonial.company}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
