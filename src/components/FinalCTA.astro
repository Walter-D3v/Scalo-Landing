---

<section id="contacto" class="relative overflow-hidden bg-white scroll-mt-24 md:scroll-mt-28">
  <div class="cta-stage relative mx-auto max-w-[1284px] px-4 sm:px-6 md:px-8">
    <!-- Formas ancladas abajo, justo antes del footer -->
    <div
      class="cta-shapes pointer-events-none absolute left-1/2 z-0 w-[108%] max-w-[1240px] -translate-x-1/2 sm:w-full"
      aria-hidden="true"
    >
      <svg class="block h-auto w-full" viewBox="0 0 1580.53 171" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
        <circle cx="85.5" cy="85.5001" r="85.5" fill="#E0EA25" />
        <circle cx="1495.03" cy="85.5" r="85.5" fill="#5D95FD" />
        <path d="M251.614 0H885.536V101C885.536 139.66 854.196 171 815.536 171H251.614V0Z" fill="#D4CDFF" />
        <path d="M1238.53 70C1238.53 31.3401 1207.19 0 1168.53 0H885.536V101C885.536 139.66 916.876 171 955.536 171H1168.53C1207.19 171 1238.53 139.66 1238.53 101V70Z" fill="#FFEBA2" />
        <path d="M1408.31 84.8893C1408.31 38.0062 1370.3 0 1323.42 0V0C1276.53 0 1238.53 38.3105 1238.53 85.1935V85.1935C1238.53 132.414 1276.81 171 1324.03 171H1408.31V84.8893Z" fill="#F47A49" />
        <circle cx="257.111" cy="85.5" r="85.5" fill="#8942FE" />
      </svg>
      <svg class="-mt-px block h-auto w-full" viewBox="0 0 1580.53 171" fill="none" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid meet">
        <path d="M80.0034 0H713.925V101C713.925 139.66 682.585 171 643.925 171H80.0034V0Z" fill="#FDE7D7" />
        <path d="M884 76C884 34.0264 918.026 0 960 0H1504C1507.31 0 1510 2.68629 1510 6V165C1510 168.314 1507.31 171 1504 171H960C918.026 171 884 136.974 884 95V76Z" fill="#DAE6FF" />
        <path d="M714 86.1107C714 132.994 752.006 171 798.889 171V171C845.772 171 883.779 132.69 883.779 85.8065V85.8065C883.779 38.5861 845.499 0 798.279 0H714V86.1107Z" fill="#FDD543" />
        <circle cx="85.5" cy="85.5" r="85.5" fill="#F47A49" />
        <circle cx="1495.03" cy="85.5" r="85.5" fill="#5D49F6" />
      </svg>
    </div>

    <!-- Caja glass encima de las formas -->
    <div class="cta-card-wrap">
      <div class="cta-card w-full rounded-[20px] px-4 py-6 text-center sm:rounded-[28px] sm:px-7 sm:py-8 md:rounded-[35px] md:px-11 md:py-9 lg:py-10">
        <h2 class="animate-reveal mb-3 font-outfit text-[1.35rem] font-bold leading-[1.1] tracking-[-0.035em] sm:mb-5 sm:text-[1.85rem] md:mb-6 md:text-[2.65rem] lg:text-[2.85rem]">
          <span class="text-scalo-primary-dark">Tu negocio merece tomar</span><br />
          <span class="text-scalo-primary-dark">mejores decisiones.</span>
          <span class="text-deep-navy"> Empieza hoy.</span>
        </h2>
        <p
          class="animate-reveal mx-auto mb-6 max-w-[600px] font-outfit text-[13px] font-semibold leading-[1.35] text-deep-navy/70 sm:mb-8 sm:text-sm md:text-[15px] lg:text-base"
          style="transition-delay: 0.1s"
        >
          Únete al piloto fundador de Scalo. Acceso gratuito, sin compromiso y con participación directa en lo que construimos.
        </p>
        <a
          href="/waitlist"
          class="btn-scalo-dark animate-reveal inline-flex h-[48px] w-full items-center justify-center px-6 text-[12px] tracking-[0.15em] sm:w-auto sm:min-w-[220px] sm:px-10 sm:text-[13px] sm:tracking-[0.22em] md:h-[54px] md:min-w-[250px] md:text-[15px]"
          style="transition-delay: 0.2s"
        >
          PROBAR&nbsp;&nbsp;AHORA
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .cta-stage {
    min-height: clamp(19rem, 88vw, 30rem);
    padding-top: 2.75rem;
    padding-bottom: clamp(8rem, 36vw, 13rem);
  }

  .cta-shapes {
    bottom: clamp(1.25rem, 5vw, 1.75rem);
  }

  .cta-card-wrap {
    position: absolute;
    left: 50%;
    top: 40%;
    z-index: 10;
    width: calc(100% - 0.5rem);
    max-width: 780px;
    transform: translate(-50%, -50%);
  }

  .cta-card {
    border: 1px solid rgba(255, 255, 255, 0.72);
    background: rgba(217, 217, 217, 0.28);
    box-shadow:
      0 4px 20px rgba(35, 18, 70, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.55);
    -webkit-backdrop-filter: blur(16px) saturate(1.15);
    backdrop-filter: blur(16px) saturate(1.15);
  }

  @supports not ((-webkit-backdrop-filter: blur(1px)) or (backdrop-filter: blur(1px))) {
    .cta-card {
      background: rgba(245, 245, 245, 0.92);
    }
  }

  @media (min-width: 480px) {
    .cta-stage {
      padding-top: 3.25rem;
    }

    .cta-card-wrap {
      top: 42%;
      width: 100%;
    }
  }

  @media (min-width: 640px) {
    .cta-stage {
      min-height: clamp(21rem, 62vw, 30rem);
      padding-top: 3.5rem;
      padding-bottom: clamp(9rem, 28vw, 13rem);
    }

    .cta-shapes {
      bottom: 1.5rem;
      width: 100%;
    }

    .cta-card-wrap {
      top: 43%;
    }
  }

  @media (min-width: 768px) {
    .cta-stage {
      min-height: clamp(24rem, 42vw, 32rem);
      padding-top: 4rem;
      padding-bottom: clamp(10rem, 18vw, 14rem);
    }

    .cta-shapes {
      bottom: 1.75rem;
    }

    .cta-card-wrap {
      top: 42%;
    }
  }

  @media (min-width: 1024px) {
    .cta-shapes {
      bottom: 2rem;
    }
  }
</style>
