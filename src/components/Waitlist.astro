---
// Waitlist.astro
---

<section id="waitlist" class="py-24 relative overflow-hidden bg-deep-navy border-t border-white/5">
  <div class="absolute inset-0 bg-gradient-to-b from-transparent to-scalo-accent-violet/5 pointer-events-none"></div>
  
  <!-- Glow background -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] bg-scalo-accent-violet/10 blur-[100px] -z-10 rounded-full pointer-events-none"></div>

  <div class="container mx-auto px-6 relative z-10 max-w-2xl text-center">
    <span class="inline-block px-3 py-1 text-xs font-bold uppercase tracking-widest text-scalo-accent-violet border border-scalo-accent-violet/30 rounded-full mb-6 shadow-[0_0_15px_rgba(99,102,241,0.2)]">
      Early Access
    </span>
    <h2 class="text-4xl md:text-5xl font-black mb-4 font-outfit uppercase tracking-tighter text-white">
      Join the <span class="text-scalo-accent-violet">Waitlist</span>
    </h2>
    <p class="text-slate-400 mb-10 text-lg">
      Sé uno de los primeros en experimentar la próxima generación de Business Intelligence. Regístrate ahora para obtener acceso anticipado.
    </p>

    <div class="bg-white/5 border border-white/10 backdrop-blur-md rounded-2xl p-6 md:p-8 shadow-2xl text-left relative overflow-hidden">
      <!-- Success Message (hidden by default) -->
      <div id="waitlist-success" class="absolute inset-0 bg-deep-navy/95 backdrop-blur flex flex-col items-center justify-center hidden z-20 transition-opacity duration-300">
        <div class="w-16 h-16 bg-scalo-accent-violet/20 rounded-full flex items-center justify-center mb-4 text-scalo-accent-violet text-3xl">
          🚀
        </div>
        <h3 class="text-2xl font-bold text-white mb-2 font-outfit">You're on the list!</h3>
        <p class="text-slate-400 text-center px-4">Gracias por tu interés. Te contactaremos muy pronto.</p>
      </div>

      <form id="waitlist-form" class="space-y-4">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div class="space-y-1.5">
            <label for="name" class="text-sm font-medium text-slate-300 ml-1">Nombre Completo <span class="text-red-500">*</span></label>
            <input 
              type="text" 
              id="name" 
              name="name" 
              required
              placeholder="Tu nombre" 
              class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:outline-none focus:ring-2 focus:ring-scalo-accent-violet focus:border-transparent transition-all"
            />
          </div>
          <div class="space-y-1.5">
            <label for="email" class="text-sm font-medium text-slate-300 ml-1">Correo Electrónico <span class="text-red-500">*</span></label>
            <input 
              type="email" 
              id="email" 
              name="email" 
              required
              placeholder="tu@email.com" 
              class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:outline-none focus:ring-2 focus:ring-scalo-accent-violet focus:border-transparent transition-all"
            />
          </div>
        </div>

        <div class="space-y-1.5">
          <label for="problem" class="text-sm font-medium text-slate-300 ml-1">¿Qué problema quieres resolver? <span class="text-slate-500 text-xs font-normal">(Opcional)</span></label>
          <textarea 
            id="problem" 
            name="problem" 
            rows="3"
            placeholder="Cuéntanos un poco sobre tu caso de uso..." 
            class="w-full bg-black/40 border border-white/10 rounded-xl px-4 py-3 text-white placeholder:text-slate-600 focus:outline-none focus:ring-2 focus:ring-scalo-accent-violet focus:border-transparent transition-all resize-none"
          ></textarea>
        </div>

        <!-- Error Message (hidden by default) -->
        <div id="waitlist-error" class="hidden text-red-400 text-sm py-1 font-medium text-center">
          Ocurrió un error. Por favor, intenta nuevamente.
        </div>

        <button 
          type="submit" 
          id="waitlist-submit"
          class="w-full bg-scalo-accent-violet hover:bg-scalo-accent-violet/90 text-white font-bold py-3.5 px-6 rounded-xl transition-all duration-300 flex items-center justify-center gap-2 group relative overflow-hidden"
        >
          <span class="relative z-10 flex items-center gap-2">
            Unirse a la lista
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" viewBox="0 0 20 20" fill="currentColor">
              <path fill-rule="evenodd" d="M10.293 3.293a1 1 0 011.414 0l6 6a1 1 0 010 1.414l-6 6a1 1 0 01-1.414-1.414L14.586 11H3a1 1 0 110-2h11.586l-4.293-4.293a1 1 0 010-1.414z" clip-rule="evenodd" />
            </svg>
          </span>
          <!-- Loading Spinner (hidden by default) -->
          <svg id="waitlist-spinner" class="animate-spin -ml-1 mr-3 h-5 w-5 text-white hidden absolute" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
          </svg>
        </button>
      </form>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('waitlist-form') as HTMLFormElement;
  const submitBtn = document.getElementById('waitlist-submit') as HTMLButtonElement;
  const spinner = document.getElementById('waitlist-spinner') as HTMLElement;
  const btnText = submitBtn?.querySelector('span') as HTMLElement;
  const successMsg = document.getElementById('waitlist-success') as HTMLElement;
  const errorMsg = document.getElementById('waitlist-error') as HTMLElement;

  if (form) {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      // Basic validation
      const formData = new FormData(form);
      const name = formData.get('name') as string;
      const email = formData.get('email') as string;
      
      if (!name || !email) return;

      // Email regex basic validation
      const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailRegex.test(email)) {
        errorMsg.textContent = "Por favor ingresa un correo válido.";
        errorMsg.classList.remove('hidden');
        return;
      }

      // UI Loading state
      submitBtn.disabled = true;
      submitBtn.classList.add('opacity-80', 'cursor-not-allowed');
      btnText.classList.add('invisible');
      spinner.classList.remove('hidden');
      errorMsg.classList.add('hidden');

      try {
        const response = await fetch('/api/waitlist', {
          method: 'POST',
          body: formData,
        });

        const result = await response.json();

        if (!response.ok) {
          throw new Error(result.error || 'Network error');
        }

        // Show success
        successMsg.classList.remove('hidden');
        form.reset();
        
      } catch (error) {
        console.error('Error submitting waitlist:', error);
        errorMsg.textContent = "Ocurrió un error. Por favor, intenta nuevamente.";
        errorMsg.classList.remove('hidden');
      } finally {
        // Reset loading state
        submitBtn.disabled = false;
        submitBtn.classList.remove('opacity-80', 'cursor-not-allowed');
        btnText.classList.remove('invisible');
        spinner.classList.add('hidden');
      }
    });
  }
</script>
