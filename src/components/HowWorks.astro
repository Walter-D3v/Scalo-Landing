---
export interface Step {
  number: string;
  title: string;
  description: string;
  icon?: string;
}

export interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  steps: Step[];
}

const { title, subtitle, description, steps } = Astro.props as Props;
---

<section id="how" class="py-24 px-8 relative overflow-hidden">
  <!-- Decorative background -->
  <div class="absolute bottom-0 -left-1/5 w-[600px] h-[600px] rounded-full bg-[radial-gradient(circle,rgba(6,182,212,0.1)_0%,transparent_70%)] pointer-events-none"></div>

  <div class="container mx-auto">
    <div class="text-center mb-16 relative z-10 reveal">
      <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-4">{title}</h2>
      {subtitle && <p class="text-xl mb-4 bg-clip-text text-transparent bg-gradient-to-r from-scalo-accent-cyan to-scalo-primary font-semibold">{subtitle}</p>}
      {description && <p class="text-base text-slate-400 max-w-2xl mx-auto">{description}</p>}
    </div>

    <div class="grid gap-8 max-w-3xl mx-auto relative z-10">
      {steps.map((step, index) => (
        <div 
          class="grid grid-cols-1 md:grid-cols-[100px_1fr] gap-4 md:gap-8 items-center p-6 md:p-8 bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl transition-all duration-300 relative group reveal" 
          style={`animation-delay: ${index * 0.15}s`}
        >
          <!-- Hover Effect Background -->
          <div class="absolute inset-0 bg-gradient-to-br from-scalo-accent-cyan/10 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 rounded-2xl pointer-events-none"></div>

          <div class="w-[60px] h-[60px] md:w-[80px] md:h-[80px] flex items-center justify-center text-2xl md:text-3xl font-extrabold bg-gradient-to-br from-scalo-accent-cyan/20 to-scalo-primary/15 rounded-xl text-scalo-accent-cyan shrink-0 z-10 relative">
            {step.number}
          </div>
          <div class="flex flex-col gap-2 z-10 relative group-hover:translate-x-2 transition-transform duration-300">
            <h3 class="text-xl font-bold text-white">{step.title}</h3>
            <p class="text-[0.95rem] text-slate-400 leading-relaxed">{step.description}</p>
          </div>
          {index < steps.length - 1 && (
            <div class="absolute left-1/2 bottom-[-40px] md:bottom-[-50px] text-3xl text-scalo-accent-cyan opacity-60 transform -translate-x-1/2 rotate-0 md:rotate-90">
              →
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</section>
