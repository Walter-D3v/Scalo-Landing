---
const steps = [
  {
    number: '1',
    title: 'Conecta tu negocio',
    titleLines: ['Conecta', 'tu negocio'],
    description: 'Conecta la información de tu empresa en un solo lugar, sin complicaciones.',
  },
  {
    number: '2',
    title: 'Scalo analiza',
    description: 'La plataforma cruza tu información interna con tendencias de tu industria y detecta lo que importa antes de que tú lo veas.',
  },
  {
    number: '3',
    title: 'Tú decides',
    description: 'Recibes recomendaciones concretas en lenguaje claro. Sin reportes que nadie lee. Sin incertidumbre.',
  },
];
---

<section id="como-funciona" class="bg-gradient-to-b from-white via-[#FDFAF6] to-white-linen py-12 md:py-16 lg:py-[72px]">
  <div class="container mx-auto max-w-[1120px] px-4 sm:px-6">
    <div class="animate-reveal mb-9 text-center md:mb-11 lg:mb-12">
      <h2 class="mb-2 font-outfit text-[1.75rem] font-bold leading-tight tracking-tight text-deep-navy sm:text-3xl md:text-4xl lg:text-[2.65rem]">
        ¿Cómo funciona?
      </h2>
      <p class="font-outfit text-[15px] font-semibold text-deep-navy/55 md:text-[17px]">
        Tres pasos. Sin curva de aprendizaje.
      </p>
    </div>

    <div class="how-steps-trigger pointer-events-none" aria-hidden="true"></div>

    <div class="how-steps-grid grid grid-cols-1 gap-5 sm:grid-cols-2 sm:gap-6 lg:grid-cols-3 lg:gap-8">
      {steps.map((step, i) => (
        <article
          class="how-card relative flex flex-row items-start gap-3 overflow-hidden rounded-[22px] bg-white px-5 py-6 shadow-[0_6px_18px_rgba(16,14,50,0.16)] sm:flex-col sm:gap-0 sm:p-0 md:rounded-[24px] lg:rounded-[26px]"
        >
          <div class="how-card-number-wrap relative shrink-0 sm:h-[150px] sm:w-full sm:overflow-hidden lg:h-[165px]" aria-hidden="true">
            <span class="how-card-number font-outfit font-extrabold leading-none text-[#EDE5DC] select-none sm:absolute sm:-top-1 sm:left-6">
              {step.number}
            </span>
          </div>

          <div
            class="how-card-content relative flex min-w-0 flex-1 flex-col sm:-mt-3 sm:px-8 sm:pb-9"
            style={`--step-delay: ${0.2 + i * 0.5}s`}
          >
            {step.titleLines ? (
              <h3 class="mb-2 font-outfit text-[1.15rem] font-bold leading-[1.12] tracking-[-0.025em] text-deep-navy sm:mb-3 sm:text-2xl md:text-[1.7rem] lg:text-[1.85rem]">
                {step.titleLines.map((line) => (
                  <span class="block">{line}</span>
                ))}
              </h3>
            ) : (
              <h3 class="mb-2 font-outfit text-[1.15rem] font-bold leading-[1.12] tracking-[-0.025em] text-deep-navy sm:mb-3 sm:text-2xl md:text-[1.7rem] lg:text-[1.85rem]">
                {step.title}
              </h3>
            )}
            <p class="font-outfit text-[13px] font-semibold leading-[1.28] text-deep-navy/70 sm:text-[15px] md:text-base lg:text-[17px] lg:leading-[1.22]">
              {step.description}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<script>
  const section = document.getElementById('como-funciona');
  const trigger = section?.querySelector('.how-steps-trigger');
  const grid = section?.querySelector('.how-steps-grid');
  const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

  function setStepsVisible(visible: boolean) {
    grid?.classList.toggle('how-steps-visible', visible);
  }

  if (prefersReducedMotion) {
    setStepsVisible(true);
  } else if (trigger && grid) {
    let hasPlayed = false;

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting || hasPlayed) return;
          hasPlayed = true;
          setStepsVisible(true);
          observer.disconnect();
        });
      },
      {
        threshold: 0,
        rootMargin: '-30% 0px -40% 0px',
      }
    );

    observer.observe(trigger);
  }
</script>

<style>
  .how-card {
    min-height: auto;
  }

  .how-card-number {
    font-size: clamp(4.75rem, 22vw, 6.5rem);
    letter-spacing: -0.055em;
  }

  .how-card-content {
    opacity: 0;
    transform: translateY(14px);
    transition:
      opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
    transition-delay: var(--step-delay, 0s);
  }

  .how-steps-visible .how-card-content {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .how-card-content {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (min-width: 640px) {
    .how-card {
      min-height: 290px;
    }

    .how-card-number {
      font-size: clamp(8.75rem, 14vw, 12.5rem);
    }
  }

  @media (min-width: 1024px) {
    .how-card {
      min-height: 338px;
    }
  }
</style>
