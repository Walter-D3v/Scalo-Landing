---
const currentYear = new Date().getFullYear();
---

<footer class="py-20 bg-deep-navy/80 border-t border-white/5 relative overflow-hidden">
  <div class="container mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 mb-16 md:mb-20 relative z-10">
    <!-- Brand Info -->
    <div class="col-span-2 md:col-span-1">
      <div class="flex items-center gap-2 mb-6">
        <img src="/Scalo-logoWhite.png" alt="Scalo" class="h-12 w-auto" />
      </div>
      <p class="text-slate-400 text-sm leading-relaxed mb-6 font-outfit font-light">
        Transformando datos complejos en decisiones estratégicas efectivas. 
        Nuestra misión es empoderar a la próxima generación de startups.
      </p>
      
      <!-- Socials -->
      <div class="flex items-center gap-4">
        <a href="https://www.instagram.com/scalolatam/" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-400 hover:bg-scalo-primary hover:text-white transition-all duration-300">Ig</a>
        <a href="https://www.linkedin.com/company/scalolatam/" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-400 hover:bg-scalo-primary hover:text-white transition-all duration-300">in</a>
      </div>
    </div>

    <!-- Links -->

    <div>
      <h4 class="text-white mb-6 font-outfit font-bold">Compañía</h4>
      <ul class="space-y-4 text-sm text-slate-400 mb-6 font-outfit font-normal">
        <li><a href="#" class="hover:text-scalo-accent-cyan transition-colors">Sobre nosotros</a></li>
        <li><a href="https://iterocompany.com/" class="hover:text-scalo-accent-cyan transition-colors">Itero Company</a></li>
        <li><a href="/blog" class="hover:text-scalo-accent-cyan transition-colors">Nuestro Blog</a></li>
      </ul>
    </div>
  </div>

  <div class="container mx-auto px-6 border-t border-white/5 pt-8 md:pt-10 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-slate-500 font-outfit font-thin tracking-widest relative z-10 text-center md:text-left">
    <p>© {currentYear} Scalo. Todos los derechos reservados.</p>
    <div class="flex items-center gap-6">
      <div class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
        Un producto de <a href="https://iterocompany.com/" rel="Itero Company" class="hover:text-scalo-accent-cyan transition-colors">Itero Company</a>
      </div>
      <div>Hecho con ❤️ por scalo team</div>
    </div>
  </div>
  
  <!-- Subtle Gradient Decoration -->
  <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-scalo-primary/10 blur-[120px] rounded-full"></div>
  <div class="absolute -bottom-24 -right-24 w-72 h-72 bg-scalo-accent-violet/10 blur-[120px] rounded-full"></div>
</footer>
