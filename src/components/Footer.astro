---
const currentYear = new Date().getFullYear();
---

<footer
  class="footer-shell relative z-20 -mt-6 bg-deep-navy pt-12 pb-[calc(2.25rem+env(safe-area-inset-bottom,0px))] sm:-mt-8 sm:pt-14 md:-mt-12 md:pt-16 md:pb-[calc(2.5rem+env(safe-area-inset-bottom,0px))] lg:-mt-[60px] lg:pt-[4.5rem] lg:pb-[calc(3rem+env(safe-area-inset-bottom,0px))]"
>
  <div class="footer-inner mx-auto max-w-[1284px] px-6 sm:px-8 md:px-12 lg:px-16 xl:px-20">
    <div class="footer-main mb-10 grid gap-10 sm:mb-11 sm:gap-11 md:mb-14 md:grid-cols-2 md:items-start md:gap-12 lg:gap-20">
      <div class="footer-brand max-w-[300px]">
        <img
          src="/images/home/logo-white.png"
          alt="Scalo"
          class="mb-5 h-[4rem] w-auto sm:mb-6 sm:h-[4.25rem] lg:h-[4.75rem]"
        />
        <p class="mb-5 max-w-[280px] font-outfit text-[13px] leading-[1.5] text-white/85 md:text-sm md:leading-[1.55]">
          <span class="block">Tus datos ya existen.</span>
          <span class="block">Scalo los convierte en decisiones estratégicas que generan crecimiento.</span>
        </p>
        <a
          href="mailto:hola@scalolatam.com"
          class="inline-block font-outfit text-[13px] text-scalo-primary-50 transition-colors hover:text-white md:text-sm"
        >
          hola@scalolatam.com
        </a>
      </div>

      <div class="footer-links flex flex-col gap-8 md:items-end md:pt-1 lg:pt-2">
        <div class="grid grid-cols-2 gap-x-10 gap-y-3.5 font-outfit text-[13px] text-white sm:gap-x-14 md:ml-auto md:gap-x-16 md:text-sm lg:gap-x-20">
          <a href="/#producto" class="transition-colors hover:text-scalo-primary-50">Producto</a>
          <a href="/#faqs" class="transition-colors hover:text-scalo-primary-50">Precio</a>
          <a href="/#como-funciona" class="transition-colors hover:text-scalo-primary-50">Acerca</a>
          <a href="/#contacto" class="transition-colors hover:text-scalo-primary-50">Contacto</a>
        </div>

        <div class="md:text-right">
          <h4 class="mb-3 font-outfit text-[13px] font-bold text-white md:text-sm">Síganos en redes sociales</h4>
          <div class="flex items-center gap-1.5 md:justify-end">
            <a
              href="https://www.linkedin.com/company/scalolatam/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-9 w-9 items-center justify-center rounded-full text-white transition-colors hover:bg-white/10 hover:text-scalo-primary-50 sm:h-10 sm:w-10"
              aria-label="LinkedIn"
            >
              <svg class="h-4 w-4 sm:h-[18px] sm:w-[18px]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 114.126 0 2.063 2.063 0 01-2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
            </a>
            <a
              href="https://www.instagram.com/scalolatam/"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex h-9 w-9 items-center justify-center rounded-full text-white transition-colors hover:bg-white/10 hover:text-scalo-primary-50 sm:h-10 sm:w-10"
              aria-label="Instagram"
            >
              <svg class="h-4 w-4 sm:h-[18px] sm:w-[18px]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>

    <div class="border-t border-white/10 pt-6 text-center sm:pt-7">
      <p class="font-outfit text-[10px] uppercase leading-relaxed tracking-[0.22em] text-white/55 sm:text-[11px] sm:tracking-[0.34em] md:text-xs md:tracking-[0.4em]">
        Un producto de
        <a
          href="https://iterocompany.com/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-white/75 underline underline-offset-[5px] transition-colors hover:text-white"
        >
          Itero Company
        </a>
        <span class="sr-only"> · © {currentYear} Scalo.</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-shell {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
    border-top-left-radius: 2.5rem;
    border-top-right-radius: 2.5rem;
    overflow: hidden;
  }

  @media (min-width: 640px) {
    .footer-shell {
      border-top-left-radius: 3rem;
      border-top-right-radius: 3rem;
    }
  }

  @media (min-width: 768px) {
    .footer-shell {
      border-top-left-radius: 4rem;
      border-top-right-radius: 4rem;
    }
  }

  @media (min-width: 1024px) {
    .footer-shell {
      border-top-left-radius: 5rem;
      border-top-right-radius: 5rem;
    }
  }

  @media (min-width: 1280px) {
    .footer-shell {
      border-top-left-radius: 6rem;
      border-top-right-radius: 6rem;
    }
  }
</style>
