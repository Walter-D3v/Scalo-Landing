---
const currentYear = new Date().getFullYear();
---

<footer class="py-20 bg-deep-navy/80 border-t border-white/5 relative overflow-hidden">
  <div class="container mx-auto px-6 grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-12 mb-16 md:mb-20 relative z-10">
    <!-- Brand Info -->
    <div class="col-span-2 md:col-span-1">
      <div class="flex items-center gap-2 mb-6">
        <img src="/Scalo-logoWhite.png" alt="Scalo" class="h-12 w-auto" />
      </div>
      <p class="text-slate-400 text-sm leading-relaxed mb-6">
        Transformando datos complejos en decisiones estratégicas efectivas. 
        Nuestra misión es empoderar a la próxima generación de startups.
      </p>
      
      <!-- Socials -->
      <div class="flex items-center gap-4">
        <a href="#" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-400 hover:bg-scalo-primary hover:text-white transition-all duration-300">𝕏</a>
        <a href="#" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-400 hover:bg-scalo-primary hover:text-white transition-all duration-300">in</a>
        <a href="#" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-400 hover:bg-scalo-primary hover:text-white transition-all duration-300">gh</a>
      </div>
    </div>

    <!-- Links -->
    <div>
      <h4 class="text-white font-bold mb-6 font-outfit">Producto</h4>
      <ul class="space-y-4 text-sm text-slate-400">
        <li><a href="#features" class="hover:text-scalo-accent-cyan transition-colors">Características</a></li>
        <li><a href="#" class="hover:text-scalo-accent-cyan transition-colors">Inicio</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6 font-outfit">Recursos</h4>
      <ul class="space-y-4 text-sm text-slate-400">
        <li><a href="#" class="hover:text-scalo-accent-cyan transition-colors">Blog</a></li>
      </ul>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6 font-outfit">Compañía</h4>
      <ul class="space-y-4 text-sm text-slate-400 mb-6">
        <li><a href="#" class="hover:text-scalo-accent-cyan transition-colors">Sobre Nosotros</a></li>
        <li><a href="#" class="hover:text-scalo-accent-cyan transition-colors">Carreras</a></li>
      </ul>
      
      <!-- Redes Sociales de Compañía -->
      <div class="flex items-center gap-4 mt-8 pt-4 border-t border-white/5">
        <a href="#" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-400 hover:bg-[#0A66C2] hover:text-white transition-all duration-300" title="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
        </a>
        <a href="#" target="_blank" rel="noopener noreferrer" class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center text-slate-400 hover:bg-gradient-to-tr hover:from-yellow-400 hover:via-pink-500 hover:to-purple-500 hover:text-white transition-all duration-300" title="Instagram">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
        </a>
      </div>
    </div>
  </div>

  <div class="container mx-auto px-6 border-t border-white/5 pt-8 md:pt-10 flex flex-col md:flex-row items-center justify-between gap-4 text-xs text-slate-500 font-bold uppercase tracking-widest relative z-10 text-center md:text-left">
    <p>© {currentYear} Scalo. Todos los derechos reservados.</p>
    <div class="flex items-center gap-6">
      <div class="flex items-center gap-2">
        <span class="w-1.5 h-1.5 bg-emerald-500 rounded-full animate-pulse"></span>
        System Operational
      </div>
      <div>HECHO CON ❤️ POR SCALO TEAM</div>
    </div>
  </div>
  
  <!-- Subtle Gradient Decoration -->
  <div class="absolute -bottom-24 -left-24 w-72 h-72 bg-scalo-primary/10 blur-[120px] rounded-full"></div>
  <div class="absolute -bottom-24 -right-24 w-72 h-72 bg-scalo-accent-violet/10 blur-[120px] rounded-full"></div>
</footer>
